{
  "name": "meeting-coach",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "dev:web": "turbo run dev --filter=web",
    "dev:server": "turbo run dev --filter=server",
    "deploy:thor": "./scripts/deploy-thor.sh"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1"
  }
}
